{
  "expo": {
    "name": "cue-clock",
    "slug": "cue-clock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_cropped.png",
    "scheme": "cueclock",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yanukadeneth99.cueclock"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_cropped.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.yanukadeneth99.cueclock"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_flat.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "111035b7-c94e-43f7-91de-25d6430cf0f5"
      }
    }
  }
}
