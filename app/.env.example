# ============================================
# OPTIONAL — Analytics (skip for local dev)
# ============================================
# Microsoft Clarity project ID. Optional — analytics are skipped if not provided.
# Get one at: https://clarity.microsoft.com
EXPO_PUBLIC_CLARITY_KEY=""

# ============================================
# OPTIONAL — Android Release Signing
# (Only needed to build release APKs)
# ============================================
# Base64-encoded Android keystore (.jks file)
ANDROID_KEYSTORE_BASE64=""

# Keystore password
ANDROID_KEYSTORE_PASSWORD=""

# Key alias within the keystore
ANDROID_KEY_ALIAS=""

# Key password (may be same as ANDROID_KEYSTORE_PASSWORD)
ANDROID_KEY_PASSWORD=""

# ============================================
# OPTIONAL — EAS Build Configuration
# (Only used in CI/CD workflows)
# ============================================
# Expo EAS project ID for official builds. Defaults to "dev-local-open-source" for local development.
# Get yours at: https://expo.dev
EAS_PROJECT_ID=""

# Expo account owner name. Defaults to "open-source-contributor" for local development.
EAS_OWNER=""
