{
  "name": "cue-clock",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web && node scripts/inject-seo-meta.js",
    "build:web:deploy": "node scripts/derive-web-version.js && npm run build:web",
    "lint": "expo lint",
    "test": "bash ../tests/ai/scripts/test-all.sh web && bash ../tests/ai/scripts/test-all.sh device",
    "test:web": "bash ../tests/ai/scripts/test-all.sh web",
    "test:android": "bash ../tests/ai/scripts/test-all.sh device",
    "test:modern": "bash ../tests/ai/scripts/test-all.sh modern",
    "test:old": "bash ../tests/ai/scripts/test-all.sh old"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@microsoft/react-native-clarity": "^4.5.3",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-firebase/perf": "^23.8.8",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@types/react": "~19.2.10",
    "expo": "^55.0.26",
    "expo-alarm-vibrator": "file:./modules/expo-alarm-vibrator",
    "expo-asset": "~55.0.16",
    "expo-audio": "~55.0.14",
    "expo-build-properties": "~55.0.14",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-notifications": "~55.0.23",
    "expo-router": "^55.0.16",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "luxon": "^3.7.1",
    "protobufjs": "^7.6.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-modal-datetime-picker": "^18.0.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@types/luxon": "^3.7.1",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.1",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "postcss": "^8.5.10",
    "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6",
    "shell-quote": ">=1.8.4",
    "@grpc/grpc-js": ">=1.9.16",
    "uuid": ">=11.1.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@notifee/react-native",
          "@microsoft/react-native-clarity"
        ]
      }
    }
  }
