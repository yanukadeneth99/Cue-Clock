# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native (generated by npx expo run:android / run:ios)
android/
ios/
# Exception: local Expo modules under app/modules/*/android/ are source, not generated.
!app/modules/*/android/
!app/modules/*/android/**
# But the build/ directory inside those modules IS generated — still ignore it.
app/modules/*/android/build/
app/modules/*/android/.cxx/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

release.keystore
.env
!.env.example
.artifacts/

# AI test harness
tests/ai/results/
tests/ai/.venv/
tests/ai/web/.venv/
tests/ai/web/__pycache__/
tests/ai/android/node_modules/
# Un-ignore the harness source — the top-level android/ rule would otherwise swallow it
!tests/ai/android/
!tests/ai/android/**
tests/ai/android/node_modules/
!tests/ai/scenarios/*

docs/superpowers

# Editor & tool configs
.vscode/
.remember/

# Claude Code
.claude/*
!.claude/skills/
!.claude/launch.json
